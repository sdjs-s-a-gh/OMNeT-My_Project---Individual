config *.mdAutonomousVehicle[*].wlan[0].radio.transmitter.power 1.4mW
config *.mdAutonomousVehicle[*].wlan[0].radio.transmitter.preambleDuration 10us
config *.mdAutonomousVehicle[*].wlan[0].radio.transmitter.headerLength 8B
config *.mdAutonomousVehicle[*].wlan[0].radio.receiver.sensitivity -85dBm
config *.mdAutonomousVehicle[*].wlan[0].radio.receiver.energyDetection -85dBm
config *.mdAutonomousVehicle[*].wlan[0].radio.receiver.snirThreshold 4dB
config *.baseStation.forwarding true
