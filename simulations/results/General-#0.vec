config image-path ../../../default_workspace/inet-4.5.4/images
config description "Simple sim where two nodes communicate wirelessly."
config network ResourceNetwork
config sim-time-limit 60s
config *.*.ipv4.arp.typename GlobalArp
config *.mdAutonomousVehicle[*].numApps 1
config *.mdAutonomousVehicle[*].app[0].typename TrafficGenerator
config *.mdAutonomousVehicle[*].app[0].destAddresses "\"edgeServer\""
config *.mdAutonomousVehicle[*].app[0].destPort 5000
config *.mdAutonomousVehicle[*].app[0].messageLength 1024B
config *.mdAutonomousVehicle[*].app[0].sendInterval exponential(0.000032s)
config *.mdAutonomousVehicle[*].app[0].packetName "\"TaskData\""
config *.mdAutonomousVehicle[*].app[0].minRequiredCPUCycles 300
config *.mdAutonomousVehicle[*].app[0].maxRequiredCPUCycles 500
config *.mdAutonomousVehicle[*].app[0].minDeadlineLatency 0.5
config *.mdAutonomousVehicle[*].app[0].maxDeadlineLatency 20
config *.edgeServer*.numApps 1
config *.edgeServer*.app[0].typename ResourceAllocatorApp
config *.edgeServer*.app[0].localPort 5000
config *.host*.wlan[0].typename AckingWirelessInterface
config *.host*.wlan[0].mac.useAck false
config *.host*.wlan[0].mac.fullDuplex false
config *.host*.wlan[0].radio.transmitter.communicationRange 500m
config *.host*.wlan[0].mac.headerLength 23B
config *.mdMobilePhone.wlan[0].typename AckingWirelessInterface
config *.mdMobilePhone.wlan[0].mac.useAck false
config *.mdMobilePhone.wlan[0].mac.fullDuplex false
config *.mdMobilePhone.wlan[0].radio.transmitter.communicationRange 500m
config *.mdMobilePhone.wlan[0].mac.headerLength 23B
config *.mdAutonomousVehicle[*].wlan[0].typename AckingWirelessInterface
config *.mdAutonomousVehicle[*].wlan[0].mac.useAck false
config *.mdAutonomousVehicle[*].wlan[0].mac.fullDuplex false
config *.mdAutonomousVehicle[*].wlan[0].radio.transmitter.communicationRange 500m
config *.mdAutonomousVehicle[*].wlan[0].mac.headerLength 23B
config *.baseStation.forwarding true
config *.baseStation*.wlan[0].typename AckingWirelessInterface
config *.baseStation*.wlan[0].mac.useAck false
config *.baseStation*.wlan[0].mac.fullDuplex false
config *.baseStation*.wlan[0].radio.transmitter.communicationRange 500m
config *.baseStation*.wlan[0].mac.headerLength 23B
config *.host*.**.bitrate 1Mbps
config *.baseStation*.wlan[0].bitrate 1Mbps
config *.mdMobilePhone.wlan[0].bitrate 1Mbps
config *.mdAutonomousVehicle*.wlan[0].bitrate 2500Mbps
config **.radio.displayCommunicationRange true
config *.visualizer.mediumVisualizer.displaySignals true
config *.visualizer.physicalLinkVisualizer.displayLinks true
config *.visualizer.physicalLinkVisualizer.packetFilter "\"TaskData\""
config *.visualizer.mobilityVisualizer.displayVelocities true
config *.visualizer.mobilityVisualizer.displayMovementTrails true
config *.hostA.mobility.typename LinearMobility
config *.hostA.mobility.speed 12mps
config *.hostA.mobility.initialMovementHeading 200deg

