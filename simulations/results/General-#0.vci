config *.hostA*.app[0].maxRequiredCPUCycles 1000
config *.hostA*.app[0].minDeadlineLatency 1
config *.hostA*.app[0].maxDeadlineLatency 10
config *.mdMobilePhone.numApps 1
config *.mdMobilePhone.app[0].typename TrafficGenerator
config *.mdMobilePhone.app[0].destAddresses "\"edgeServer\""
config *.mdMobilePhone.app[0].destPort 5000
config *.mdMobilePhone.app[0].messageLength 1024B
config *.mdMobilePhone.app[0].sendInterval exponential(12ms)
config *.mdMobilePhone.app[0].packetName "\"TaskData\""
config *.mdMobilePhone.app[0].minRequiredCPUCycles 100
config *.mdMobilePhone.app[0].maxRequiredCPUCycles 200
config *.mdMobilePhone.app[0].minDeadlineLatency 20
config *.mdMobilePhone.app[0].maxDeadlineLatency 30
config *.edgeServer*.numApps 1
config *.edgeServer*.app[0].typename ResourceAllocatorApp
config *.edgeServer*.app[0].localPort 5000
config *.host*.wlan[0].typename AckingWirelessInterface
config *.host*.wlan[0].mac.useAck false
config *.host*.wlan[0].mac.fullDuplex false
config *.host*.wlan[0].radio.transmitter.communicationRange 500m
config *.host*.wlan[0].mac.headerLength 23B
config *.mdMobilePhone.wlan[0].typename AckingWirelessInterface
config *.mdMobilePhone.wlan[0].mac.useAck false
config *.mdMobilePhone.wlan[0].mac.fullDuplex false
