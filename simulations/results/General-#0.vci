config *.mdMobilePhone.wlan[0].mac.headerLength 23B
config *.baseStation.forwarding true
config *.baseStation*.wlan[0].typename AckingWirelessInterface
config *.baseStation*.wlan[0].mac.useAck false
config *.baseStation*.wlan[0].mac.fullDuplex false
config *.baseStation*.wlan[0].radio.transmitter.communicationRange 500m
config *.baseStation*.wlan[0].mac.headerLength 23B
config *.host*.**.bitrate 1Mbps
